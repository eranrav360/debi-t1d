# ── Database ────────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooler URL is fine for all services)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── Dexcom Share credentials ─────────────────────────────────────────────────────
# The Dexcom account that shares Debi's readings
DEXCOM_USERNAME=your_dexcom_email@example.com
DEXCOM_PASSWORD=your_dexcom_password

# Server region: 'us' for US accounts, 'ous' for all other countries (Israel = ous)
DEXCOM_SERVER=ous

# ── Alert thresholds (mg/dL) ─────────────────────────────────────────────────────
ALERT_URGENT_LOW=55
ALERT_LOW=70
ALERT_HIGH=180
ALERT_URGENT_HIGH=250

# Optional: POST alert payloads to this URL (Slack, Make, IFTTT, etc.)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Dexcom server port ────────────────────────────────────────────────────────────
PORT_DEXCOM=3009

# ── CORS ─────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://debi.144-24-171-177.sslip.io,https://debi-t1d.vercel.app
